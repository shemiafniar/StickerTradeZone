# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these values in your Supabase project: Settings -> API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public site URL used for the "share with friends" links (WhatsApp/copy
# link) and Web Share API. Set this to your deployed domain in production
# (e.g. https://shashot.app or your Vercel URL).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Admin dashboard: user deletion (optional, but required for that one
# feature specifically) -----------------------------------------------------
# Only used server-side, only inside Server Actions that have already
# verified the caller is an admin (see requireAdmin() in
# src/lib/actions/admin.ts). Required for the "מחיקת משתמש לצמיתות"
# (permanently delete user) admin action, which needs the Auth Admin API to
# remove the underlying auth.users row (deleting just the profiles row
# would leave an orphaned, still-loginable auth.users entry). Every other
# admin feature (suspend/reactivate, edit, view, trades management,
# statistics) works without this key. Find it in your Supabase project's
# Settings -> API -> service_role key (marked "secret" - never expose this
# to the client, never commit it, never prefix it with NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# --- AI Sticker Scanner (optional) ---------------------------------------
# If OPENAI_API_KEY is not set, the AI Scanner automatically falls back to a
# built-in mock provider so the full upload -> review -> save flow still
# works end-to-end without any external dependency. Set this key to enable
# real sticker-number/album-slot detection via OpenAI's vision-capable
# models. See src/lib/vision/index.ts to add other providers.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
